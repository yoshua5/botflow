# ============================================================
# AGENTFLOW — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets to git.
# All secrets marked with ⚠️ must ONLY exist in Vercel env vars.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# ⚠️  Service Role key — bypasses RLS. Server-side only. NEVER expose to browser.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Encryption ───────────────────────────────────────────────
# AES-256 key for encrypting API keys stored in bot_secrets.
# ⚠️  Must be a 64-character hex string. NEVER put in Supabase or git.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_string_here

# ── Webhook security ─────────────────────────────────────────
# Random secret for HMAC ownership verification of phone_number_id → user bindings.
# ⚠️  Must be a random 32+ character string. NEVER put in Supabase or git.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
WEBHOOK_SECRET=your_random_webhook_secret_here

# ── Meta (WhatsApp) ──────────────────────────────────────────
# From Meta Developer Console → App → Settings → Basic → App Secret
# ⚠️  Used to verify X-Hub-Signature-256 on incoming webhook POST requests.
META_APP_SECRET=your_meta_app_secret_here

# Token used during WhatsApp webhook registration (GET /api/webhook).
# Must match the "Verify token" you enter in Meta Developer Console.
# Use a random string — NOT "botflow123".
WA_VERIFY_TOKEN=your_random_verify_token_here

# Default WhatsApp credentials (for env-var-based single-user mode, pre-Supabase).
# These are OVERRIDDEN by per-user secrets stored in Supabase bot_secrets.
# Can be left empty once all users are migrated to Supabase.
WA_ACCESS_TOKEN=
WA_PHONE_NUMBER_ID=
WA_BUSINESS_ID=
WA_VERIFY_TOKEN=

# ── Clerk (Authentication) ───────────────────────────────────
# From clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Stripe ───────────────────────────────────────────────────
# From stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Anthropic ────────────────────────────────────────────────
# Global fallback API key — overridden by per-user key in bot_secrets.
ANTHROPIC_KEY=sk-ant-...

# ── OpenAI (Whisper transcription) ───────────────────────────
# Global fallback — overridden by per-user key in bot_secrets.
OPENAI_API_KEY=sk-...

# ── Migration flag ───────────────────────────────────────────
# Set to "true" ONLY after:
#   1. Running: node scripts/migrate-kv-to-supabase.js --dry-run (no errors)
#   2. Running: node scripts/migrate-kv-to-supabase.js (migration successful)
#   3. Running: node scripts/backfill-ownership-hmac.js
USE_SUPABASE=false

# ── Vercel KV (legacy — kept for migration fallback) ─────────
# Remove these after USE_SUPABASE=true is confirmed stable in production.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_URL=
KV_REST_API_READ_ONLY_TOKEN=
